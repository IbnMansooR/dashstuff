{
  "name": "worktrack",
  "version": "0.1.0",
  "private": true,
  "description": "WorkTrack — hodimlar ish vaqtini kuzatuvchi SaaS (agent + server + dashboard)",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/dashboard",
    "packages/landing",
    "packages/agent"
  ],
  "scripts": {
    "dev": "concurrently -n server,panel,sayt -c blue,green,magenta \"npm:dev:server\" \"npm:dev:dashboard\" \"npm:dev:landing\"",
    "dev:server": "npm run dev --workspace=@worktrack/server",
    "dev:dashboard": "npm run dev --workspace=@worktrack/dashboard",
    "dev:landing": "npm run dev --workspace=@worktrack/landing",
    "dev:agent": "npm run dev --workspace=@worktrack/agent",
    "build:dashboard": "npm run build --workspace=@worktrack/dashboard",
    "build:landing": "npm run build --workspace=@worktrack/landing"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
