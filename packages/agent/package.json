{
  "name": "@worktrack/agent",
  "version": "0.1.0",
  "private": true,
  "description": "Feekr hodim agenti — ish vaqtini kuzatadi (Electron, Windows + Mac)",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "uz.feekr.agent",
    "productName": "Feekr",
    "files": ["main.cjs", "preload.cjs", "renderer/**/*"],
    "directories": { "output": "dist", "buildResources": "build" },
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8"
  }
}
